{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chip-supply-chain-map.local/roles/product.spec-writer/output.schema.json",
  "title": "SpecWriterOutput",
  "description": "Spec ledger artifact the spec-writer produces per change.",
  "type": "object",
  "required": ["spec_id", "requirement_ids", "files", "decisions"],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^\\d{4}-[a-z0-9][a-z0-9-]*$",
      "description": "Spec folder name under specs/."
    },
    "requirement_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^R-[A-Z]+-\\d{3,}$"},
      "minItems": 1
    },
    "files": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 6,
      "description": "Relative paths of the six ledger files produced."
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement", "dec_path"],
        "additionalProperties": false,
        "properties": {
          "requirement": {"type": "string", "pattern": "^R-[A-Z]+-\\d{3,}$"},
          "dec_path": {"type": "string"}
        }
      }
    }
  }
}
