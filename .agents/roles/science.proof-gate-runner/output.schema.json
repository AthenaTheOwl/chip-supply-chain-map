{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chip-supply-chain-map.local/roles/science.proof-gate-runner/output.schema.json",
  "title": "ProofGateRunnerOutput",
  "description": "Gate-run artifact the proof-gate-runner emits per change.",
  "type": "object",
  "required": ["change_id", "gate_results", "decision"],
  "additionalProperties": false,
  "properties": {
    "change_id": {"type": "string"},
    "gate_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec_check",
        "voice_lint",
        "validate_decisions",
        "validate_roles",
        "validate_tools",
        "validate_policies",
        "build"
      ],
      "properties": {
        "spec_check": {"type": "string", "enum": ["passing", "failing"]},
        "voice_lint": {"type": "string", "enum": ["passing", "failing"]},
        "validate_decisions": {"type": "string", "enum": ["passing", "failing"]},
        "validate_roles": {"type": "string", "enum": ["passing", "failing"]},
        "validate_tools": {"type": "string", "enum": ["passing", "failing"]},
        "validate_policies": {"type": "string", "enum": ["passing", "failing"]},
        "build": {"type": "string", "enum": ["passing", "failing"]}
      }
    },
    "decision": {"type": "string", "enum": ["approved", "blocked"]},
    "report_path": {"type": "string"}
  }
}
