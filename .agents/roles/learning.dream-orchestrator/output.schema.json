{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chip-supply-chain-map.local/roles/learning.dream-orchestrator/output.schema.json",
  "title": "DreamOrchestratorOutput",
  "description": "Per-week dream artifact set. The full structured output also conforms to the cross-repo dream-output.schema.json from athena-site.",
  "type": "object",
  "required": ["week", "report_path", "candidates"],
  "additionalProperties": false,
  "properties": {
    "week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$"
    },
    "report_path": {"type": "string"},
    "output_json_path": {"type": "string"},
    "modes_run": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "memory_consolidation",
          "failure_clustering",
          "adversarial_simulation",
          "counterfactual",
          "skill_extraction",
          "golden_test_generation",
          "prompt_patch_generation",
          "architecture_drift_detection"
        ]
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "evidence", "human_review_required"],
        "additionalProperties": true,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["memory_update", "test_generation", "skill_patch", "backlog_item"]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "human_review_required": {"type": "boolean", "const": true}
        }
      }
    }
  }
}
